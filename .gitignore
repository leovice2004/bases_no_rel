# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
# Prevents cross-OS dependencies problems
uv.lock

# Ignore generated *.docker-compose.yml
*-cluster.docker-compose.yml
*.docker-compose.yml

# cassandra ignore
cassandra/cluster_certs
cassandra/mount/cassandra-node-*
cassandra/mount/jmxremote.password
cassandra/mount/cassandra.yaml

# neo4j ignore
neo4j/mount/data
neo4j/mount/neo4j
neo4j/mount/plugins

# hadoop data
hadoop/mount/datanode-*
hadoop/mount/namenode
hadoop/mount/nodemanager-*
hadoop/mount/resourcemanager
hadoop/mount/hive-metastore
hadoop/mount/hive-metastore-db
hadoop/mount/hive-server2
hadoop/envs
hadoop/data.csv
hadoop/sales.csv

# spark data
spark/vscode_server
spark/mount/spark-master
spark/mount/spark-warehouse
spark/mount/spark-worker-*
spark/mount/iceberg-warehouse
spark/mount/local-warehouse
spark/mount/spark-jupyter/data
spark/mount/spark-jupyter/spark_job_env.tar.gz
spark/mount/spark-jupyter/metastore_db
spark/mount/spark-jupyter/derby.log
spark/mount/spark-jupyter/.*
spark/mount/shared-workspace/data
spark/mount/shared-workspace/spark-warehouse
spark/mount/shared-workspace/iceberg-warehouse
spark/mount/shared-workspace/local-warehouse
spark/mount/shared-workspace/derby.log

# mongodb data
mongodb/config/*
mongodb/mount/*
mongodb/mongo-keyfile

# redis data
redis/mount/redis-node-*

# opensearch data
opensearch/mount/*
